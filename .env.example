# ════════════════════════════════════════════════
# Copy file này thành .env.local khi dev local
# Trên Vercel: điền vào Settings → Environment Variables
# ════════════════════════════════════════════════

# ── Tài khoản ngân hàng ACB ──────────────────────
ACB_ACCOUNT=YOUR_ACB_ACCOUNT_NUMBER
ACCOUNT_NAME=CT TNHH HANADOLA MEDIA & TECHNOLOGY

# ── SePay ────────────────────────────────────────
# Lấy tại: my.sepay.vn → Cài đặt → API
SEPAY_API_KEY=YOUR_SEPAY_APIKEY

# ── Resend (gửi email) ────────────────────────────
# Đăng ký miễn phí tại: resend.com
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=no-reply@hanadola.com

# ── Thông tin sản phẩm ────────────────────────────
EBOOK_LINK=YOUR_GOOGLE_DRIVE_LINK
NOTIFY_EMAIL=admin@hanadola.com

# ── (Tùy chọn) Hóa đơn điện tử ───────────────────
# Điền nếu dùng nhà cung cấp e-Invoice (VNPT/Viettel/MISA)
# EINVOICE_API_URL=https://api.einvoice-provider.vn/create
# EINVOICE_API_KEY=YOUR_EINVOICE_KEY

# ── Vercel KV (tự động thêm khi tạo KV trên Vercel) ─
# KV_URL=...
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
# KV_REST_API_READ_ONLY_TOKEN=...
